Bootstrap: docker
From: pytorch/pytorch:2.0.1-cuda11.7-cudnn8-runtime

%labels
    AUTHOR_NAME Alexandre Venturi
    VERSION 1.0

%environment

%files
    requirements.txt /opt/requirements.txt

%post
    apt-get update && apt-get install -y git gcc libgl1-mesa-glx libglib2.0-0
    pip install --no-cache-dir -r /opt/requirements.txt